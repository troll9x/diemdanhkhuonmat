# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-to-another-random-secret-key

# Database
DATABASE_URI=sqlite:///attendance.db
# For production, use PostgreSQL:
# DATABASE_URI=postgresql://user:password@localhost:5432/attendance_db

# Security
BCRYPT_LOG_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,xlsx,csv

# Geolocation
ATTENDANCE_RADIUS_METERS=100
LATE_THRESHOLD_MINUTES=15

# ML Models
CONFIDENCE_THRESHOLD=0.60
ANTISPOOF_THRESHOLD=0.50
MIN_FACE_CAPTURES=20
TARGET_FACE_CAPTURES=30

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@attendance.edu

# System Settings
SCHOOL_NAME=Smart Attendance University
TIMEZONE=Asia/Ho_Chi_Minh

# API Documentation
SWAGGER_URL=/api/docs
API_URL=/api/swagger.json